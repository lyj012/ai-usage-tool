# Copy to .env only for local use. Do not commit real secrets.

# Remote HTTP MCP bearer token. Use a long random value before exposing via tunnel.
AIUSAGE_MCP_TOKEN=

# Optional server-controlled config path for Remote HTTP MCP.
# Remote callers cannot override this value through MCP tool arguments.
AIUSAGE_MCP_CONFIG=aiusage-config.json

# Optional person name used by run_workday_report.bat.
AIUSAGE_PERSON=

# Optional config path used by run_workday_report.bat.
AIUSAGE_CONFIG=aiusage-config.json
